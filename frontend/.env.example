# Base URL of the pipeline API (the FastAPI service).
#
# PIPELINE_API_URL is the one to set in production. It is read server-side by
# the /run route handler, which proxies to the backend — so the browser never
# talks to it directly and no CORS configuration is needed. Leave it unset and
# the app runs standalone on bundled sample data.
PIPELINE_API_URL=http://localhost:8000

# Optional, and usually unnecessary: point the browser at the backend directly,
# bypassing this app's own route handlers. Requires the backend to allow this
# origin via CORS. Prefer PIPELINE_API_URL above.
# NEXT_PUBLIC_API_URL=http://localhost:8000
